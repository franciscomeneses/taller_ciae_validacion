fit_indices <- lapply(modelos, function(m) {
fitMeasures(m, c("cfi","rmsea","srmr"))
}) %>%
bind_rows(.id = "modelo")
# Calcular deltas respecto al modelo anterior
fit_indices <- fit_indices %>%
arrange(match(modelo, c("basico","agrupado","carga","umbrales","residuos"))) %>%
mutate(
delta_cfi = c(NA, diff(cfi)),
delta_rmsea = c(NA, diff(rmsea)),
delta_srmr = c(NA, diff(srmr))
)
# Mostrar tabla
fit_indices
save(fit_indices, "output/invariance_table_4b.RData")
save(fit_indices, file="output/invariance_table_4b.RData")
load(file="images/invariance_table_4b.RData")
load(file="images/invariance_table_4b.RData")
library(kableExtra)
fit_indices
fit_indices %>% kableExtra::kbl()
