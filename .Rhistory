list_anio =  unique(apod_consolidada$anio)
mat_segregation_2002 = apod_consolidada %>%
select(rbd,nse_dec,anio) %>%
filter(anio==2003) %>%
na.omit() %>%
group_by(rbd,nse_dec) %>%
summarise(n=n()) %>%
select(
unit=rbd,
group=nse_dec,
n
) %>% ungroup()
for (anio_bucle in list_anio) {
mat_segregation = apod_consolidada %>%
select(rbd,nse_dec,anio) %>%
filter(anio==anio_bucle) %>%
na.omit() %>%
group_by(rbd,nse_dec) %>%
summarise(n=n()) %>%
select(
unit=rbd,
group=nse_dec,
n
) %>% ungroup()
result_dis = segregation::mutual_difference(mat_segregation_2002, mat_segregation, "group", "unit", weight = "n")
matriz_anio <- data.frame(anio = anio_bucle,
resultado = result_dis[8, 2] %>% as.numeric()
,base=result_dis[1, 2] %>% as.numeric())
matriz_anio = matriz_anio %>% mutate(
final = 100 + (resultado/base)*100
)
assign(paste0("df_diff_",anio_bucle), matriz_anio)
}
