ggplot2::ggplot(aes(y = as.numeric(final), x = as.numeric(anio), group = 1)) +
geom_line()  +
#  geom_ribbon(aes(ymin = est_low, ymax = est_high),alpha =0.3) +
geom_point() +
theme_bw() +
# geom_text(aes(label=(final) %>% round(1)),vjust=-0.8,size = 3 ) +
geom_text(aes(label=(final) %>% round(1)),vjust=-0.8,colour="#3c8089", size = 4,check_overlap = TRUE,
fontface="bold") +
geom_vline(xintercept = c(2008,2015,2020), linetype="dotted")  +
ggtitle("Segragación del sistema chileno: Indice M corregido") +
ylab("Indice H de Theil") +
xlab("Años")   +
scale_x_continuous(breaks = seq(2003, 2023, 1), limits = c(2003, 2023)); plot
plot
