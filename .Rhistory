list_variables = c("a_nse_dec_20","b_nse_dec_40","c_nse_dec_60","d_nse_dec_80") # ,"e_nse_dec_100"
for (variablevariable in list_variables ) {
list_anio =  unique(apod_consolidada$anio)
for (anio_bucle in list_anio) {
mat_segregation = apod_consolidada %>%
select(rbd,!!sym(variablevariable),anio) %>%
filter(anio==anio_bucle) %>%
na.omit() %>%
group_by(rbd,!!sym(variablevariable)) %>%
summarise(n=n()) %>%
select(
unit=rbd,
group=!!sym(variablevariable),
n
) %>% ungroup()
result_dis = dissimilarity(mat_segregation,"group", "unit", weight = "n")
matriz_anio <- data.frame(anio = anio_bucle, resultado = result_dis[1, 2])
assign(paste0("df_",variablevariable,"_",anio_bucle), matriz_anio)
}
bbdd_nombres <- ls(pattern = paste0("df_",variablevariable) )
matriz_duncan_anio = do.call(rbind, lapply(bbdd_nombres, get))
objetos_envirement = ls()
rm(list = paste0("df_",variablevariable))
matriz_duncan_anio$grupo= variablevariable
assign(paste0("matriz_duncan_anio_q_",variablevariable),
matriz_duncan_anio )
}
bbdd_nombres <- ls(pattern = "matriz_duncan_anio_q_")
matriz_duncan_periodo = do.call(rbind, lapply(bbdd_nombres, get))
library(ggplot2)
plot=matriz_duncan_periodo %>%
ggplot2::ggplot(aes(y = as.numeric(est), x = as.numeric(anio), group = grupo,shape = grupo, colour = grupo)) +
geom_line()  +
geom_point() +
geom_text(aes(label=(as.numeric(est)*100) %>% round(1)),vjust=-0.2, colour="black", size = 3,check_overlap = TRUE ) +
ggtitle("Cambio segragación del sistema chileno: Indice de Duncan" ) +
ylab("Indice de Disimilitud Duncan") +
xlab("Años") +
scale_x_continuous(breaks = seq(2003, 2023, 1), limits = c(2003, 2023))  +
geom_vline(xintercept = c(2008,2015,2020), linetype="dotted")  +
scale_colour_grey(start = 0.1, end = 0.8, name = "NSE", labels = c("20% más vulnerable", "40% más vulnerable","60% más vulnerable","80% más vulnerable")) +
scale_shape_discrete(name = "NSE", labels = c("20% más vulnerable", "40% más vulnerable","60% más vulnerable","80% más vulnerable"))+
theme_bw() +
theme(legend.position="bottom"); plot
ggsave(plot, file="output/2m/segregacion_duncan_q1q5_2m.png", width = 20, height = 15, units = "cm" )
