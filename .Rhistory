apod_consolidada =  apod_consolidada %>% group_by(anio, rbd)  %>% mutate(
n_estudiantes =  n()
) %>% mutate(n_chiquito =  ifelse( n_estudiantes<15,  1 ,0 )) %>% ungroup()
