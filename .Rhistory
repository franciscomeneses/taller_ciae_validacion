apod_consolidada  =  apod_consolidada %>%  filter( #n_comuna_5nochicos ==0  &
n_chiquito == 0
)
apod_consolidada %>% group_by(anio,cod_depe2) %>% filter(!is.na(nse_factorial)) %>%
summarise(n=n()) %>%
mutate(cod_depe2 =  case_when(
cod_depe2==0 ~ "Publico",
cod_depe2==1 ~ "P.SUB",
cod_depe2==2 ~ "P.PART"
),
prop = round(n/sum(n),4) * 100 ) %>% select(-n) %>%
tidyr::pivot_wider(names_from = cod_depe2, values_from = prop)
apod_consolidada %>% group_by(anio,cod_depe2) %>%
mutate(is_na_nse  =
ifelse(
is.na(ingresos_fam) | is.na(educ_madre) | is.na(educ_padre),
1,
0
)) %>%
summarise( na_nse = mean(is_na_nse*100) %>% round(1) %>% paste0("%") ) %>%
mutate(cod_depe2 =  case_when(
cod_depe2==1 ~ "Publico",
cod_depe2==2 ~ "P.SUB",
cod_depe2==3 ~ "P.PART"
)) %>%
tidyr::pivot_wider(names_from = cod_depe2, values_from = na_nse)
apod_consolidada  = apod_consolidada  %>%
filter(
!(anio %in% c(2010))
)
apod_consolidada$anio_char =  paste0("A",apod_consolidada$anio)
# Comunas que participan todo el periodo
df_comunas_presentes_anio = apod_consolidada %>% select(cod_com_rbd, anio_char) %>%
mutate(comuna_presente =1,comuna_anio = paste0(cod_com_rbd,anio_char) ) %>% filter(!duplicated(comuna_anio))%>% select(-comuna_anio)%>%
tidyr::pivot_wider(names_from = anio_char, values_from = comuna_presente) %>%
rowwise() %>%  mutate(sum_presente_comunanio = sum(c_across(starts_with("A2")), na.rm=T) ) %>%
select(cod_com_rbd,sum_presente_comunanio)
df_comunas_presentes_anio$sum_presente_comunanio %>% summary()
apod_consolidada = apod_consolidada   %>%  left_join(df_comunas_presentes_anio, by="cod_com_rbd" )
#apod_consolidada =  apod_consolidada %>%  filter(sum_presente_comunanio == 11)
# Establecimientos que participan todo el periodo
df_colegio_presentes_anio = apod_consolidada %>% select(rbd, anio_char) %>%
mutate(colegio_presente =1,rbd_anio = paste0(rbd,anio_char) ) %>%
filter(!duplicated(rbd_anio))%>% select(-rbd_anio)%>%
tidyr::pivot_wider(names_from = anio_char, values_from = colegio_presente) %>%
rowwise() %>%  mutate(sum_presente_coleanio = sum(c_across(starts_with("A2")), na.rm=T) ) %>%
select(rbd,sum_presente_coleanio)
df_colegio_presentes_anio$sum_presente_coleanio %>% summary()
apod_consolidada = apod_consolidada   %>%  left_join(df_colegio_presentes_anio, by="rbd" )
#apod_consolidada =  apod_consolidada %>%  filter(sum_presente_coleanio == 11)
apod_consolidada %>% group_by(anio) %>%
summarise(
n=n(),
n_nse = sum(!is.na(nse_factorial))) %>%
mutate(prop=(n_nse/n)*100 )
apod_consolidada_rec = apod_consolidada %>%
filter( (!is.na(educ_madre) & !is.na(educ_padre) ) & !is.na(ingresos_fam)   ) %>%
filter(
!(anio %in% c(2010))
) %>%
select(mrun,anio_char,educ_madre, educ_padre, ingresos_fam)
nse_factorial_model <- 'nse_factorial_long =~  educ_madre + educ_padre + ingresos_fam'
mod_conf_cfa <- cfa(nse_factorial_model ,
data = apod_consolidada_rec %>% group_by(anio_char) %>% mutate(
educ_madre = scale(educ_madre),
educ_padre = scale(educ_padre),
ingresos_fam = scale(ingresos_fam)) %>% ungroup()
,
group="anio_char",
group.equal = c("loadings"
, "intercepts",
"residuals"
)
)
lavaan::summary(mod_conf_cfa,standardized = TRUE,fit.measures=T)
apod_consolidada_rec %>% group_by(anio_char)  %>% summarise(n())
