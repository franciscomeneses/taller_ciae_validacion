fscores <- lavPredict(mod_conf_cfa)
list_anios =  unique(apod_consolidada$anio)
#
# c(2002,2005,
#                     2008, 2012:2018,2022:2023)
for (anio_afc  in list_anios  ) {
nombre_bbdd = paste0("A",anio_afc)
fscores_anio  =   fscores[[nombre_bbdd]] %>% as.data.frame()
apod_consolidada_rec_anio = apod_consolidada_rec %>% filter(anio_char==nombre_bbdd)
for (fs in colnames(fscores_anio)) {
apod_consolidada_rec_anio$nse_factorial_long  <- fscores_anio$nse_factorial_long %>% as.numeric()
}
apod_consolidada_rec_anio= apod_consolidada_rec_anio %>% select(mrun,anio_char,nse_factorial_long)
assign(paste0("apod_nse_long_",anio_afc),apod_consolidada_rec_anio)
}
# Paso 1: Obtener todos los objetos en el entorno que tengan "_reorder" en su nombre
bbdd_nombres <- ls(pattern = "apod_nse_long_")
# Paso 2: Usar lapply para obtener cada base de datos y luego combinar con rbind
apod_afc_cons <- do.call(rbind, lapply(bbdd_nombres, get))
# Paso 3: borrar todas las bbdd menos la consolidada
objetos_envirement = ls()
rm(list =  bbdd_nombres)
## loop over factors
apod_afc_cons$mrun_anio = paste0(apod_afc_cons$mrun,apod_afc_cons$anio_char)
apod_afc_cons =  apod_afc_cons  %>%  filter(!duplicated(mrun_anio))
apod_consolidada = apod_consolidada %>% left_join(apod_afc_cons,by=c("mrun","anio_char"))
##### CALCULO DE QUINTILES AFC LONGITUDINAL INVARIANTE.
apod_consolidada  = apod_consolidada %>%
group_by(anio) %>%
mutate( nse_dec = ntile(nse_factorial_long, 5)) %>%
ungroup() %>%
mutate(
a_nse_dec_20 = case_when(
nse_dec == 1 ~ 1,
nse_dec > 1 ~ 0,
TRUE ~ NA ),
b_nse_dec_40 = case_when(
nse_dec == 1 | nse_dec == 2 ~ 1,
!(nse_dec == 1 | nse_dec == 2) ~ 0,
TRUE ~ NA ),
c_nse_dec_60 = case_when(
nse_dec == 1 | nse_dec == 2 | nse_dec == 3 ~ 1,
!(nse_dec == 1 | nse_dec == 2 | nse_dec == 3) ~ 0,
TRUE ~ NA ),
d_nse_dec_80 = case_when(
nse_dec == 1 | nse_dec == 2 | nse_dec == 3  | nse_dec == 4 ~ 1,
nse_dec == 5 ~ 0,
TRUE ~ NA )
# ,
# e_nse_dec_100 = case_when(
#   nse_dec == 5 ~ 1,
#   nse_dec != 5 ~ 0,
#   TRUE ~ NA )
)
apod_consolidada %>% dim()
library(lme4)
library(mlmhelpr)
list_anio =  unique(apod_consolidada$anio)
for (anio_bucle in list_anio) {
lmer_model_anio=lme4::lmer(nse_factorial_long~ 1 + (1 | rbd) , data = apod_consolidada %>% filter(anio==anio_bucle))
icc_object = mlmhelpr::icc(lmer_model_anio)
matriz_anio <- matrix(c(anio_bucle, icc_object[1,2]), nrow = 1, ncol = 2)
assign(paste0("matriz_icc_",anio_bucle), matriz_anio)
}
# Paso 1: Obtener todos los objetos en el entorno que tengan "_reorder" en su nombre
bbdd_nombres <- ls(pattern = "matriz_icc_")
# Paso 2: Usar lapply para obtener cada base de datos y luego combinar con rbind
matriz_icc_anios <- do.call(rbind, lapply(bbdd_nombres, get))
# Paso 3: borrar todas las bbdd menos la consolidada
objetos_envirement = ls()
rm(list = setdiff(objetos_envirement, c("matriz_icc_anios","apod_consolidada" )))
matriz_icc_anios = matriz_icc_anios %>% as.data.frame()
matriz_icc_anios = matriz_icc_anios %>% select(anio=V1, icc=V2)
library(ggplot2)
plot=matriz_icc_anios %>%
ggplot2::ggplot(aes(y = as.numeric(icc), x = as.numeric(anio), group = 1)) +
geom_line()  +
geom_point() +
theme_bw() +
geom_text(aes(label=round(as.numeric(icc),2)  ), nudge_y = 0.005)  +
ggtitle("Cambio de la correlación intraclase") +
ylab("Correlación intraclase") +
xlab("Años") +
scale_x_continuous(breaks = seq(2003, 2023, 1), limits = c(2003, 2023))  +
geom_vline(xintercept = 2019, linetype="dotted")   ; plot
ggsave(plot, file="output/2m/segregacion_icc_continuo_2m.png", width = 30, height = 15, units = "cm" )
